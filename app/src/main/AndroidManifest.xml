<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_idle_bloom"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@drawable/ic_idle_bloom"
        android:supportsRtl="true"
        android:theme="@style/Theme.IdleBloom"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".settings.SettingsActivity"
            android:banner="@drawable/tv_banner"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".preview.PreviewSlideshowActivity"
            android:exported="false"
            android:label="@string/app_name" />

        <service
            android:name=".dream.IdleBloomDreamService"
            android:exported="true"
            android:icon="@drawable/ic_idle_bloom"
            android:label="@string/dream_name"
            android:permission="android.permission.BIND_DREAM_SERVICE">

            <intent-filter>
                <action android:name="android.service.dreams.DreamService" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <meta-data
                android:name="android.service.dream"
                android:resource="@xml/idle_bloom_dream" />
        </service>
    </application>

</manifest>
