<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1016"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/appTitleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
            android:textColor="#F5F7FA" />

        <TextView
            android:id="@+id/subtitleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_subtitle"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="#9FB1C1" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/baseUrlInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/field_base_url"
            app:boxBackgroundMode="filled"
            app:helperText="@string/field_base_url_helper">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/baseUrlEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/text_input_background"
                android:imeOptions="actionNext"
                android:inputType="textUri"
                android:minHeight="56dp"
                android:padding="16dp"
                android:textColor="#F5F7FA"
                android:textColorHint="#6D8194" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/usernameInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/field_username"
            app:boxBackgroundMode="filled">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/usernameEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/text_input_background"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:minHeight="56dp"
                android:padding="16dp"
                android:textColor="#F5F7FA"
                android:textColorHint="#6D8194" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/passwordInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/field_password"
            app:boxBackgroundMode="filled"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/passwordEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/text_input_background"
                android:imeOptions="actionNext"
                android:inputType="textPassword"
                android:minHeight="56dp"
                android:padding="16dp"
                android:textColor="#F5F7FA"
                android:textColorHint="#6D8194" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/remoteDirectoryInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/field_remote_directory"
            app:boxBackgroundMode="filled"
            app:helperText="@string/field_remote_directory_helper">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/remoteDirectoryEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/text_input_background"
                android:imeOptions="actionNext"
                android:inputType="text"
                android:minHeight="56dp"
                android:padding="16dp"
                android:textColor="#F5F7FA"
                android:textColorHint="#6D8194" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/intervalInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/field_interval_seconds"
            app:boxBackgroundMode="filled"
            app:helperText="@string/field_interval_helper">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/intervalEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/text_input_background"
                android:imeOptions="actionDone"
                android:inputType="number"
                android:minHeight="56dp"
                android:padding="16dp"
                android:textColor="#F5F7FA"
                android:textColorHint="#6D8194" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/shuffleSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/field_shuffle"
            android:textColor="#F5F7FA" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:text="@string/action_save" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/testConnectionButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="60dp"
                android:text="@string/action_test_connection" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/previewButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="60dp"
                android:text="@string/action_preview_slideshow" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/text_input_background"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/statusTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_waiting"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="#9FB1C1" />

            <TextView
                android:id="@+id/diagnosticsTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:textColor="#C8D2DC"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</ScrollView>
